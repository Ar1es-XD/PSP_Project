# Shared environment defaults
EVOLVER_LOG_LEVEL=INFO
EVOLVER_UPDATE_EVERY=50
EVOLVER_STEP_DELAY=0.0
EVOLVER_DEFAULT_CHARSET=ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz1234567890 _+=~!@#$%^&*(){}[]|;:<>,.?/
EVOLVER_MAX_TARGET_LENGTH=256
EVOLVER_MAX_CHARSET_LENGTH=512
EVOLVER_MAX_BODY_BYTES=4096
EVOLVER_MAX_ACTIVE_SIMULATIONS=200
EVOLVER_RATE_LIMIT_RPS=10
EVOLVER_RATE_LIMIT_BURST=20
EVOLVER_WEBSOCKET_HEARTBEAT_INTERVAL=15
EVOLVER_WEBSOCKET_MAX_MISSED=3
EVOLVER_OTEL_ENABLED=false
EVOLVER_OTEL_ENDPOINT=http://localhost:4317
EVOLVER_OTEL_SERVICE_NAME=password-evolver
EVOLVER_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/password_evolver
EVOLVER_REDIS_URL=redis://localhost:6379/0
EVOLVER_REDIS_CHANNEL_PREFIX=simulation:
EVOLVER_CELERY_BROKER_URL=redis://localhost:6379/0
EVOLVER_CELERY_RESULT_BACKEND=redis://localhost:6379/0
EVOLVER_DB_POOL_SIZE=5
EVOLVER_DB_MAX_OVERFLOW=10
EVOLVER_DB_POOL_TIMEOUT=30
EVOLVER_DB_POOL_RECYCLE=1800
EVOLVER_ALEMBIC_INI_PATH=backend/alembic.ini
EVOLVER_WORKER_HEARTBEAT_INTERVAL=10
EVOLVER_WORKER_HEARTBEAT_CHANNEL=workers:heartbeat
EVOLVER_WORKER_HEARTBEAT_KEY=workers:heartbeat:last
EVOLVER_WORKER_HEARTBEAT_TTL=30
EVOLVER_WORKER_METRICS_PUSHGATEWAY=
EVOLVER_WORKER_METRICS_JOB=password-evolver-worker
EVOLVER_CELERY_TASK_SOFT_TIME_LIMIT=20
EVOLVER_CELERY_TASK_TIME_LIMIT=30
EVOLVER_CELERY_TASK_MAX_RETRIES=3
EVOLVER_CELERY_RETRY_BACKOFF_BASE=0.2
EVOLVER_CELERY_RETRY_BACKOFF_CAP=5.0
EVOLVER_CELERY_QUEUE_BACKLOG_LIMIT=10000
EVOLVER_CELERY_QUEUE_KEY=simulations
EVOLVER_DLQ_REDIS_KEY=dlq:simulations
EVOLVER_REDIS_CIRCUIT_FAILURES=5
EVOLVER_REDIS_CIRCUIT_RECOVERY_SECONDS=10
EVOLVER_WORKER_MAX_TASKS_PER_CHILD=1000
EVOLVER_WORKER_MAX_MEMORY_PER_CHILD_MB=512

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8001

GATEWAY_LOG_LEVEL=INFO
GATEWAY_REDIS_URL=redis://localhost:6379/0
GATEWAY_REDIS_CHANNEL_PREFIX=simulation:
GATEWAY_SHARD_ID=0
GATEWAY_SHARD_COUNT=1
GATEWAY_HEARTBEAT_INTERVAL=15
GATEWAY_HEARTBEAT_MAX_MISSED=3
GATEWAY_PRESENCE_TTL_SECONDS=60
GATEWAY_EVENT_CACHE_TTL_SECONDS=300
GATEWAY_MAX_OUTBOUND_QUEUE=256
GATEWAY_MAX_CONNECTIONS=20000
GATEWAY_CONNECT_RATE_RPS=20
GATEWAY_CONNECT_RATE_BURST=40
GATEWAY_MESSAGE_RATE_RPS=30
GATEWAY_MESSAGE_RATE_BURST=60
GATEWAY_RECONNECT_COOLDOWN_SECONDS=3
GATEWAY_REDIS_CIRCUIT_FAILURES=5
GATEWAY_REDIS_CIRCUIT_RECOVERY_SECONDS=10
GATEWAY_SUBSCRIBER_BACKOFF_BASE=0.2
GATEWAY_SUBSCRIBER_BACKOFF_CAP=5.0
